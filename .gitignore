# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# serwist build artifacts (emitted by `next build --webpack`, never committed)
/public/sw.js
/public/sw.js.map
/public/swe-worker*.js
/public/swe-worker*.js.map

# prebaked image variants (generated by scripts/prebake-images.mjs, rebaked per box)
/public/img-cache/

# prisma
/lib/generated
/prisma/*.db
/prisma/*.db-journal
/prisma/*.db-shm
/prisma/*.db-wal

# autonomous program runner runtime state (logs, lock, manifest, counters)
/.program/

# FSRS weight-fit python venv (wave24; provisioned by scripts/fsrs-fit/setup-venv.sh)
scripts/fsrs-fit/.venv/

# throwaway wave driver logs
.wave10-plan.log
.wave10-run.log
var/log/
