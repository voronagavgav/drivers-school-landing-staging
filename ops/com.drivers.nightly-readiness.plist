<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.drivers.nightly-readiness</string>
  <!-- Nightly FSRS recompute (wave11-14). Reuses the finish-path recompute fns
       via `tsx --conditions=react-server` so the server-only marker resolves to
       its empty stub outside Next. -->
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/npx</string>
    <string>tsx</string>
    <string>--conditions=react-server</string>
    <string>scripts/nightly-readiness.ts</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key><string>/Users/clpc</string>
    <key>PATH</key><string>/opt/homebrew/bin:/opt/homebrew/sbin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
  <key>WorkingDirectory</key><string>/Users/clpc/drivers-school</string>
  <!-- 03:30 local time. launchd has no TZ key — the deploy box MUST be set to
       Europe/Kyiv (`sudo systemsetup -settimezone Europe/Kyiv`) for this to fire
       at 03:30 Kyiv. See ops/README.md. -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>3</integer>
    <key>Minute</key><integer>30</integer>
  </dict>
  <key>StandardOutPath</key><string>/Users/clpc/drivers-school/.program/nightly-readiness.out.log</string>
  <key>StandardErrorPath</key><string>/Users/clpc/drivers-school/.program/nightly-readiness.err.log</string>
  <key>ProcessType</key><string>Background</string>
</dict>
</plist>
